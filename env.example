# Copy to .env and restart Vite.
#
# AI camera works WITHOUT a key: continuous on-device obstacle detection (COCO-SSD + distances) + map route.
# Optional: set a key to use a cloud multimodal model instead (OpenAI-compatible API).

VITE_VISION_API_KEY=

# Optional when using cloud vision (defaults work for OpenAI)
# VITE_VISION_API_URL=https://api.openai.com/v1
# VITE_VISION_MODEL=gpt-4o-mini

# OpenRouter example:
# VITE_VISION_API_URL=https://openrouter.ai/api/v1
# VITE_VISION_MODEL=google/gemini-2.0-flash-001
# VITE_OPENROUTER_HTTP_REFERER=https://yoursite.example
